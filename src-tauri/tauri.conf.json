{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Almanac",
  "version": "0.2.2",
  "identifier": "com.almanac.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Almanac",
        "width": 1100,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Sorakiel/almanac/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFQ0NEM0I0MDVDODUxNjEKUldSaFVjZ0Z0TlBNWG9nRkh6RFo2YWxCRGNHRjVaM3Z6V0VYOW1xUk9FSUtUa3JIb1lWRTRYa1kK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
