# Almanac environment variables.
# Copy to .env.local (gitignored) and fill in from your Supabase project:
# Supabase Dashboard → Project Settings → API.

# Project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# The public "anon" key. Safe in the client BECAUSE Row-Level Security is on.
# NEVER put the service_role key here or anywhere in the client/repo.
VITE_SUPABASE_ANON_KEY=
